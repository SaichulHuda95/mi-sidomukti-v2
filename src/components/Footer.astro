---
const currentYear = new Date().getFullYear();
import { Image } from 'astro:assets';
import LogoImage from '../assets/img/app/logo_mi.png';
---

<footer class="bg-slate-950 text-slate-300 pt-20 pb-10">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
            <!-- Brand & Sosmed -->
            <div class="col-span-1">
                <div class="flex items-center gap-3 mb-6">
                    <Image src={LogoImage} alt="Logo MI" class="w-10" />
                    <span class="text-xl font-bold text-white tracking-tight leading-none">MI Nurul Ulum<br/><span class="text-emerald-500 text-sm font-medium tracking-widest uppercase">Sidomukti</span></span>
                </div>
                <p class="text-sm leading-relaxed mb-8 text-slate-400">
                    Membentuk generasi cerdas, berakhlak mulia, dan berwawasan luas melalui pendidikan yang unggul dan bernilai Islami.
                </p>
                <div class="flex gap-4">
                    {['facebook', 'instagram', 'youtube'].map((social) => (
                        <a href="/" class="w-10 h-10 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center hover:bg-emerald-600 hover:border-emerald-600 hover:text-white transition-all group">
                            <span class="sr-only">{social}</span>
                            <div class="w-5 h-5 bg-slate-400 group-hover:bg-white transition-colors" style={`mask: url(https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/${social}.svg) no-repeat center; -webkit-mask: url(https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/${social}.svg) no-repeat center;`}></div>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Tautan Cepat -->
            <div>
                <h4 class="text-white font-bold mb-6 relative inline-block">
                    Tautan Cepat
                    <span class="absolute -bottom-1 left-0 w-8 h-1 bg-emerald-500 rounded-full"></span>
                </h4>
                <ul class="space-y-4 text-sm">
                    <li><a href="/profil/tentang" class="hover:text-emerald-500 transition-colors flex items-center gap-2"><span>&rsaquo;</span> Tentang Kami</a></li>
                    <li><a href="/profil/sarana-prasarana" class="hover:text-emerald-500 transition-colors flex items-center gap-2"><span>&rsaquo;</span> Program Unggulan</a></li>
                    <li><a href="/kegiatan/galeri" class="hover:text-emerald-500 transition-colors flex items-center gap-2"><span>&rsaquo;</span> Galeri Kegiatan</a></li>
                    <li><a href="/kontak" class="hover:text-emerald-500 transition-colors flex items-center gap-2"><span>&rsaquo;</span> Pendaftaran</a></li>
                </ul>
            </div>

            <!-- Kontak -->
            <div>
                <h4 class="text-white font-bold mb-6 relative inline-block">
                    Kontak Kami
                    <span class="absolute -bottom-1 left-0 w-8 h-1 bg-emerald-500 rounded-full"></span>
                </h4>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>Prubungan, Sidomukti Kec. Bungah, Kabupaten Gresik, Jawa Timur</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <span>081232643577</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <span>mim.nurul.ulum.sidomukti@gmail.com</span>
                    </li>
                </ul>
            </div>

            <!-- Peta -->
            <div class="rounded-2xl overflow-hidden h-48 bg-slate-900 border border-slate-800 grayscale-0 transition-all duration-500 group">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7919.741463354669!2d112.49290388709758!3d-7.02447749999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e77e516c60cdf55%3A0x64b34712dc5d52ce!2sMI%20NURUL%20ULUM%20SIDOMUKTI%20BUNGAH%20GRESIK!5e0!3m2!1sid!2sid!4v1752770584489!5m2!1sid!2sid" 
                    class="w-full h-full border-0" allowfullscreen="" loading="lazy" title="Lokasi sekolah MI NURUL ULUM SIDOMUKTI"></iframe>
            </div>
        </div>

        <!-- Bottom -->
        <div class="border-t border-slate-900 pt-10 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-sm text-slate-500">
                &copy; {currentYear} <span class="text-slate-400">MI Nurul Ulum Sidomukti</span>. Seluruh hak cipta dilindungi.
            </p>
            <div class="flex gap-8 text-sm text-slate-500">
                <a href="/" class="hover:text-emerald-500 transition-colors">Kebijakan Privasi</a>
                <a href="https://saichul-huda.vercel.app" class="hover:text-white transition-colors underline decoration-emerald-500/30 underline-offset-4" target="_blank">Developer</a>
            </div>
        </div>
    </div>

    <!-- Floating Action Buttons -->
    <div class="fixed bottom-6 right-6 flex flex-col gap-4 z-[60]">
        <!-- WhatsApp Button -->
        <a 
            href="https://wa.me/6281232643577" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-10 h-10 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-2xl hover:bg-emerald-600 hover:scale-110 transition-all duration-300 group relative"
        >
            <span class="absolute right-full mr-3 px-3 py-1 bg-slate-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Chat Kami</span>
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
        </a>

        <!-- Scroll to Top Button -->
        <button 
            id="scroll-to-top"
            class="w-10 h-10 bg-slate-500 text-white rounded-full flex items-center justify-center shadow-3xl hover:bg-emerald-50 hover:text-emerald-600 transition-all duration-300 opacity-0 invisible translate-y-10 border border-slate-100"
            aria-label="Scroll to top"
        >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
            </svg>
        </button>
    </div>
</footer>

<script>
    const scrollBtn = document.getElementById('scroll-to-top');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
            scrollBtn?.classList.remove('opacity-0', 'invisible', 'translate-y-10');
            scrollBtn?.classList.add('opacity-100', 'visible', 'translate-y-0');
        } else {
            scrollBtn?.classList.add('opacity-0', 'invisible', 'translate-y-10');
            scrollBtn?.classList.remove('opacity-100', 'visible', 'translate-y-0');
        }
    });

    scrollBtn?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
</script>