---
import { Image } from 'astro:assets';
import heroImage from '../assets/img/app/bg_tittle.jpg';
const { titleHero } = Astro.props;
const { describeHero } = Astro.props;
---

<!-- Hero Section -->
<section class="relative py-16 md:py-24 flex items-center justify-center bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-emerald-900/60 to-slate-900 z-10"></div>
    <Image 
        src={heroImage}
        class="absolute inset-0 w-full h-full object-cover opacity-30"
        alt="Hero Background"
        loading="eager"
    />
    <div class="relative z-10 text-center text-white px-4">
        <!-- Breadcrumb -->
        <nav class="flex mt-15 justify-center" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li class="inline-flex items-center group">
                    <a href="/" class="text-sm font-medium text-gray-300 hover:text-white transition-colors">
                        Beranda
                    </a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-3 h-3 text-gray-500 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-emerald-400 md:ml-2">{titleHero}</span>
                    </div>
                </li>
            </ol>
        </nav>
        <h1 class="text-4xl md:text-6xl mt-4 font-bold tracking-tight animate-fade-in">{titleHero}</h1>
        <p class="mt-4 text-lg md:text-xl max-w-2xl mx-auto text-gray-200 leading-relaxed">{describeHero}</p>
    </div>
</section>