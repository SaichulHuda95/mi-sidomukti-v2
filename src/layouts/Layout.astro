---
import "../styles/global.css";
import 'aos/dist/aos.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { title, description, image = '/images/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://minurululum.sch.id').href;
const siteDescription = description || "MI Nurul Ulum Sidomukti adalah lembaga pendidikan dasar islam yang berfokus pada akhlakul karimah dan prestasi akademik. Daftar sekarang untuk tahun ajaran baru.";
---

<!doctype html>
<html lang="id"> <!-- Ganti ke 'id' jika kontennya Bahasa Indonesia -->
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- Judul harus unik dan mengandung keyword utama -->
        <title>{title}</title>
        
        <!-- Deskripsi yang menarik (150-160 karakter) -->
        <meta name="description" content={siteDescription} />
        
        <!-- Canonical Link untuk menghindari duplikat konten -->
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph untuk Social Media SEO -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={siteDescription} />
        <meta property="og:image" content={new URL(image, Astro.url)} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:type" content="website" />

        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <meta name="generator" content={Astro.generator} />
    </head>
    <body>
        <slot />

        <script>
        import AOS from 'aos';
        
        // Inisialisasi AOS
        // Ini akan berjalan setiap kali halaman dimuat di browser
        AOS.init({
            duration: 400, // durasi animasi (ms)
            once: true,    // animasi hanya berjalan sekali saat scroll
        });
        </script>
    </body>
</html>