---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SecondHero from '../components/SecondHero.astro'
---

<Layout title="Kontak Kami | MI Nurul Ulum Sidomukti">
    <Header />

    <main>
        <SecondHero titleHero="Kontak Kami" describeHero="Hubungi kami untuk informasi lebih lanjut mengenai pendaftaran, program pendidikan, atau kunjungan ke madrasah."/>

        <section class="py-16 px-4 max-w-6xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Informasi Kontak -->
                <div class="space-y-8" data-aos="fade-up" data-aos-duration="1000">
                    <div class="mb-10">
                        <h2 class="text-3xl font-bold text-green-700 mb-4">Hubungi Kami</h2>
                        <p class="text-gray-600">Silakan gunakan informasi di bawah ini untuk menghubungi kami secara langsung atau kunjungi lokasi kami.</p>
                    </div>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="bg-green-100 p-3 rounded-full text-green-700">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">Alamat</h3>
                                <p class="text-gray-600">Prubungan, Sidomukti Kec. Bungah, Kabupaten Gresik, Jawa Timur</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="bg-green-100 p-3 rounded-full text-green-700">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">Telepon / WhatsApp</h3>
                                <p class="text-gray-600">081232643577</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="bg-green-100 p-3 rounded-full text-green-700">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">Email</h3>
                                <p class="text-gray-600">mim.nurul.ulum.sidomukti@gmail.com</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Formulir Pesan -->
                <div class="bg-slate-50 p-8 rounded-2xl border border-gray-100" data-aos="fade-up" data-aos-duration="1000">
                    <h3 class="text-2xl font-bold mb-6">Kirim Pesan</h3>
                    <form class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label for="name" class="text-sm font-medium">Nama Lengkap</label>
                                <input type="text" id="name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none" placeholder="Nama Anda" required />
                            </div>
                            <div class="space-y-2">
                                <label for="email" class="text-sm font-medium">Email / No. HP</label>
                                <input type="text" id="email" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none" placeholder="Email atau WhatsApp" required />
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label for="subject" class="text-sm font-medium">Subjek</label>
                            <input type="text" id="subject" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none" placeholder="Tujuan pesan" required />
                        </div>
                        <div class="space-y-2">
                            <label for="message" class="text-sm font-medium">Pesan</label>
                            <textarea id="message" rows="4" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none" placeholder="Tuliskan pesan Anda di sini..." required></textarea>
                        </div>
                        <button type="submit" class="w-full bg-green-700 hover:bg-green-800 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                            Kirim Pesan
                        </button>
                    </form>
                </div>
            </div>

            <!-- Map Integration -->
            <div class="mt-16 bg-gray-200 rounded-2xl overflow-hidden h-96" data-aos="zoom-in" data-aos-duration="1000">
                <!-- Ganti SRC iframe dengan link embed Google Maps MI Nurul Ulum yang sebenarnya -->
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7919.741463354669!2d112.49290388709758!3d-7.02447749999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e77e516c60cdf55%3A0x64b34712dc5d52ce!2sMI%20NURUL%20ULUM%20SIDOMUKTI%20BUNGAH%20GRESIK!5e0!3m2!1sid!2sid!4v1752770584489!5m2!1sid!2sid" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Lokasi sekolah MI NURUL ULUM SIDOMUKTI"></iframe>
            </div>
        </section>
    </main>

    <Footer />
</Layout>