---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import SecondHero from '../../components/SecondHero.astro'
import catur from '../../assets/img/prestasi/catur.png';
import kaligrafi from '../../assets/img/prestasi/kaligrafi.png';
import lompatJauh from '../../assets/img/prestasi/lompat_jauh.png';
import mtq from '../../assets/img/prestasi/mtq.png';
import pidato from '../../assets/img/prestasi/pidato.png';
import tolakPeluru from '../../assets/img/prestasi/tolak_peluru.png';

const prestasiList = [
  {
    img: mtq,
    title: "Juara 1 MTQ Putri",
    level: "Tingkat Kecamatan",
    desc: "Prestasi gemilang dalam seni baca Al-Qur'an yang menunjukkan kedalaman spiritual dan teknik olah vokal yang mumpuni."
  },
  {
    img: kaligrafi,
    title: "Juara 2 Kaligrafi",
    level: "Tingkat Kabupaten",
    desc: "Keindahan goresan khat yang memadukan estetika seni visual dengan nilai-nilai religius yang tinggi."
  },
  {
    img: pidato,
    title: "Juara 1 Pidato Bahasa Indonesia",
    level: "Tingkat Kecamatan",
    desc: "Kemampuan orasi dan penyampaian pesan yang persuasif, melatih kepercayaan diri siswa di depan publik."
  },
  {
    img: catur,
    title: "Juara Utama Catur Putra",
    level: "Turnamen Persahabatan",
    desc: "Ketajaman strategi dan konsentrasi tinggi dalam olahraga otak, membuktikan kecerdasan intelektual siswa."
  },
  {
    img: tolakPeluru,
    title: "Juara 3 Tolak Peluru",
    level: "PORSENI Tingkat Kecamatan",
    desc: "Kekuatan fisik dan teknik yang terlatih, mencerminkan semangat sportivitas dan kerja keras dalam atletik."
  },
  {
    img: lompatJauh,
    title: "Juara Harapan 1 Lompat Jauh",
    level: "PORSENI Tingkat Kabupaten",
    desc: "Ketangkasan dan daya ledak fisik yang luar biasa dalam kompetisi atletik tingkat daerah."
  }
];
---

<Layout title="Prestasi | MI Nurul Ulum Sidomukti">
    <Header />

    <main>
        <SecondHero titleHero="Prestasi" describeHero="Apresiasi dedikasi dan bakat siswa-siswi kami dalam meraih prestasi gemilang di bidang akademik, religi, seni, hingga olahraga."/>

        <section class="py-16 px-4 max-w-7xl mx-auto">
            <div class="text-center mb-16" data-aos="fade-up">
                <h2 class="text-3xl md:text-4xl font-bold text-green-800 mb-4">Galeri Prestasi Siswa</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">Dedikasi, kerja keras, dan doa yang membuahkan hasil membanggakan bagi seluruh civitas akademika MI Nurul Ulum Sidomukti.</p>
                <div class="w-24 h-1 bg-green-600 mx-auto mt-6 rounded-full"></div>
            </div>

            <!-- Achievement Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {prestasiList.map((item, index) => (
                    <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 border border-gray-100 flex flex-col" data-aos="fade-up" data-aos-delay={index * 100}>
                        <!-- Image Section -->
                        <div class="relative h-64 overflow-hidden">
                            <Image 
                                src={item.img} 
                                alt={item.title} 
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                {...(
                                    item.title === "Juara 1 MTQ Putri" || item.title === "Juara 2 Kaligrafi" || item.title === "Juara 1 Pidato Bahasa Indonesia"
                                        ? { loading: "eager", fetchpriority: "high" }
                                        : {}
                                )}
                            />
                            <!-- Achievement Tag -->
                            <div class="absolute top-4 right-4">
                                <span class="bg-yellow-400 text-yellow-900 px-4 py-1 rounded-full text-xs font-bold shadow-sm flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                    Award
                                </span>
                            </div>
                        </div>

                        <!-- Content Section -->
                        <div class="p-8 flex-1 flex flex-col">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="w-2 h-2 bg-yellow-500 rounded-full"></span>
                                <span class="text-green-700 font-bold text-sm uppercase tracking-wider">{item.level}</span>
                            </div>
                            <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-green-700 transition-colors leading-tight">{item.title}</h3>
                            <p class="text-gray-600 text-sm leading-relaxed italic">
                                "{item.desc}"
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Call to Action Section -->
        <section class="bg-green-700 py-16 text-center text-white overflow-hidden">
            <div data-aos="zoom-in" data-aos-duration="800">
                <h2 class="text-3xl font-bold mb-4">Ingin Menjadi Bagian dari Generasi Berprestasi?</h2>
                <p class="text-green-100 mb-8 max-w-2xl mx-auto px-4">Kami berkomitmen membimbing setiap siswa untuk menemukan dan mengasah bakat terbaik mereka.</p>
                <a href="/kontak" class="bg-white text-green-700 px-8 py-3 rounded-full font-bold hover:bg-green-50 transition-colors inline-block shadow-lg">Mari Bergabung</a>
            </div>
        </section>
    </main>

    <Footer />
</Layout>