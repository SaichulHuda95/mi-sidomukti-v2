---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/img/app/hero_bg.jpg';
import kamadImage from '../assets/img/person/kamad.jpg';
import wakamad1Image from '../assets/img/person/wakamad_1.jpg';
import wakamad2Image from '../assets/img/person/wakamad_2.jpg';
import wakamad3Image from '../assets/img/person/wakamad_3.jpg';
import kegiatan1Image from '../assets/img/home/Picture1.png';
import kegiatan2Image from '../assets/img/home/Picture2.png';
import kegiatan3Image from '../assets/img/home/Picture3.png';
import kegiatan4Image from '../assets/img/home/Picture4.png';
import kegiatan5Image from '../assets/img/home/Picture5.png';
import kegiatan6Image from '../assets/img/home/Picture6.png';
import kegiatan7Image from '../assets/img/home/Picture7.png';
import kegiatan8Image from '../assets/img/home/Picture8.png';

const kegiatanList = [
	{ src: kegiatan1Image, label: "Kegiatan Matsama" },
	{ src: kegiatan2Image, label: "Kegiatan Matsama" },
	{ src: kegiatan3Image, label: "Kegiatan Matsama" },
	{ src: kegiatan4Image, label: "Kegiatan Matsama" },
	{ src: kegiatan5Image, label: "Kegiatan Pramuka" },
	{ src: kegiatan6Image, label: "Kegiatan Pramuka" },
	{ src: kegiatan7Image, label: "Peringatan Harlah ke-69" },
	{ src: kegiatan8Image, label: "Peringatan Harlah ke-72" },
];

const testimoniList = [
	{
		name: "Siti Mahmudah",
		location: "Sidomukti, Gresik",
		initials: "SM",
		quote: "Fasilitas di MI Nurul Ulum sangat memadai untuk menunjang kegiatan belajar mengajar. Keisha sangat menikmati kegiatan pramuka dan kaligrafi sehingga bisa berprestasi di bidang Non-akademik."
	},
	{
		name: "Fita Nafisa",
		location: "Sidomukti, Gresik",
		initials: "FN",
		quote: "Alhamdulillah, putri saya tidak hanya mendapatkan pendidikan agama yang kuat, tetapi juga memiliki perkembangan karakter yang positif. Hafal Juz 30 dan adabnya luar biasa."
	},
	{
		name: "Imroatul Mufidah,S.PdLi",
		location: "Sidomukti, Gresik",
		initials: "IM",
		quote: "Banyak perubahan positif baik dalam segi ibadah dan sopan santun. Saya merasa aman dan nyaman terhadap anak saya selama mengenyam pendidikan disini."
	},
	{
		name: "Nur Lailah, SE",
		location: "Sidomukti, Gresik",
		initials: "NL",
		quote: "Perkembangan kedisiplinan dan kebiasaan belajar anak saya meningkat drastis. MI Nurul Ulum bukan sekedar tempat belajar, tapi juga tempat menanamkan nilai kehidupan."
	}
];
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>
<style>
	:root { --swiper-theme-color: #10b981; }
</style>

<Layout title="Beranda | MI Nurul Ulum Sidomukti">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="relative py-32 md:py-56 flex items-center justify-center bg-slate-900 overflow-hidden">
			<Image 
				src={heroImage}
				class="absolute inset-0 w-full h-full object-cover opacity-40"
				alt="Hero Background"
				loading="eager"
			/>
			<div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-black/70"></div>
			<div class="relative z-10 text-center text-white px-4">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight">Mendidik Generasi <br/><span class="text-emerald-400">Islami & Berprestasi</span></h1>
				<p class="mt-6 text-lg md:text-2xl max-w-2xl mx-auto text-gray-200 leading-relaxed">MI Nurul Ulum Sidomukti berkomitmen membentuk siswa yang cerdas, berakhlak mulia, dan berwawasan luas melalui pendidikan bernilai Islami.</p>
				<div class="mt-10 flex flex-wrap justify-center gap-6">
					<a href="/kontak" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-full transition-all transform hover:scale-105">Daftar Sekarang</a>
					<a href="/profil/tentang" class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white font-semibold rounded-full border border-white/30 transition-all">Pelajari Lebih Lanjut</a>
				</div>
			</div>
		</section>

		<!-- Tentang Sekolah -->
		<section id="tentang" class="bg-white py-24">
			<div class="max-w-6xl mx-auto px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
					<div data-aos="fade-up" data-aos-duration="1000">
						<h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Pendidikan Berkualitas Berbasis Nilai Islam</h2>
						<p class="mt-6 text-lg text-gray-600 leading-8">MI Nurul Ulum Sidomukti memiliki Pendidik dan Tenaga Pendidik sebanyak 13 orang yang cukup berkompeten dalam melaksanaan pembelajaran dan cakap dalam penggunaan teknologi informasi (IT). Untuk jumlah murid Tahun Ajaran 2025/2026.</p>
						<p class="mt-6 text-lg text-gray-600 leading-8">MI Nurul Ulum Sidomukti berkomitmen menyelenggarakan pendidikan dasar yang mengintegrasikan kurikulum nasional dengan nilai-nilai keislaman yang kuat untuk mencetak generasi yang unggul di dunia dan akhirat.</p>
						<div class="mt-10 space-y-4">
							<div class="flex items-start gap-4">
								<div class="flex-none rounded-lg bg-emerald-50 p-2 border border-emerald-100">
									<svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
									</svg>
								</div>
								<div>
									<h4 class="font-bold text-gray-900">Kurikulum Terintegrasi</h4>
									<p class="text-gray-600">Perpaduan materi umum dan agama yang seimbang.</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<div class="flex-none rounded-lg bg-emerald-50 p-2 border border-emerald-100">
									<svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
									</svg>
								</div>
								<div>
									<h4 class="font-bold text-gray-900">Ekstrakurikuler Variatif</h4>
									<p class="text-gray-600">Mengembangkan minat dan bakat siswa sejak dini.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="grid grid-cols-2 gap-4" data-aos="fade-up" data-aos-duration="1000">
						<div class="space-y-4 pt-12">
							<Image src={wakamad1Image} alt="Wakil Kepala Madrasah" class="rounded-2xl h-64 w-full object-cover" />
							<div class="bg-emerald-600 rounded-2xl p-8 text-white">
								<p class="text-4xl font-bold italic">15+</p>
								<p class="mt-2 font-medium">Guru Profesional</p>
							</div>
						</div>
						<div class="space-y-4">
							<Image src={kamadImage} alt="Kepala Madrasah" class="rounded-2xl h-64 w-full object-cover" />
							<div class="grid grid-cols-2 gap-4">
								<Image src={wakamad2Image} alt="Wakil Kepala" class="rounded-2xl h-32 w-full object-cover" />
								<Image src={wakamad3Image} alt="Wakil Kepala" class="rounded-2xl h-32 w-full object-cover" />
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Stats Section -->
		<section class="relative z-20 -mt-12 max-w-6xl mx-auto px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
				<div class="bg-slate-50 p-6 md:p-8 rounded-3xl text-center" data-aos="fade-up" data-aos-delay="100">
					<p class="text-3xl md:text-4xl font-bold text-emerald-600">200+</p>
					<p class="text-sm md:text-base text-gray-600 font-medium">Siswa Aktif</p>
				</div>
				<div class="bg-slate-50 p-6 md:p-8 rounded-3xl text-center" data-aos="fade-up" data-aos-delay="200">
					<p class="text-3xl md:text-4xl font-bold text-emerald-600">13+</p>
					<p class="text-sm md:text-base text-gray-600 font-medium">Tenaga Pengajar</p>
				</div>
				<div class="bg-slate-50 p-6 md:p-8 rounded-3xl text-center" data-aos="fade-up" data-aos-delay="300">
					<p class="text-3xl md:text-4xl font-bold text-emerald-600">10+</p>
					<p class="text-sm md:text-base text-gray-600 font-medium">Ekstrakurikuler</p>
				</div>
				<div class="bg-slate-50 p-6 md:p-8 rounded-3xl text-center" data-aos="fade-up" data-aos-delay="400">
					<p class="text-3xl md:text-4xl font-bold text-emerald-600">50+</p>
					<p class="text-sm md:text-base text-gray-600 font-medium">Prestasi</p>
				</div>
			</div>
		</section>

		<!-- Program Unggulan -->
		<section id="program" class="py-24 bg-white relative overflow-hidden">
			<div class="max-w-6xl mx-auto px-6 lg:px-8">
				<div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
					<h2 class="text-emerald-600 font-semibold tracking-wide uppercase">Pendidikan Berkualitas</h2>
					<p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Program Unggulan Kami</p>
					<p class="mt-4 text-lg text-gray-600">Kami menghadirkan berbagai program inovatif untuk mendukung tumbuh kembang siswa secara holistik, religius, dan kreatif.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Program 1 -->
					<div class="group p-8 rounded-3xl bg-slate-50" data-aos="fade-up" data-aos-delay="100">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-6">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">Program Tahfidz Juz 30</h3>
						<p class="text-gray-600">Menanamkan kecintaan pada Al-Qur'an melalui hafalan yang terukur dan bimbingan tartil yang intensif.</p>
					</div>

					<!-- Program 2 -->
					<div class="group p-8 rounded-3xl bg-slate-50" data-aos="fade-up" data-aos-delay="200">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-6">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">Pembiasaan Ibadah</h3>
						<p class="text-gray-600">Praktik ibadah harian secara rutin (Shalat Dhuha, Dhuhur Berjamaah) untuk membentuk karakter religius.</p>
					</div>

					<!-- Program 3 -->
					<div class="group p-8 rounded-3xl bg-slate-50" data-aos="fade-up" data-aos-delay="300">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-6">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84a51.39 51.39 0 00-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">Bakat & Prestasi</h3>
						<p class="text-gray-600">Wadah eksplorasi potensi diri siswa melalui berbagai ekstrakurikuler seni, sains, dan olahraga.</p>
					</div>

					<!-- Program 4 -->
					<div class="group p-8 rounded-3xl bg-slate-50" data-aos="fade-up" data-aos-delay="400">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-6">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">Kolaborasi Prestasi</h3>
						<p class="text-gray-600">Membangun sinergi yang kuat antara guru dan orang tua untuk memantau perkembangan belajar anak.</p>
					</div>

					<!-- Program 5 -->
					<div class="group p-8 rounded-3xl bg-slate-50" data-aos="fade-up" data-aos-delay="500">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-6">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">Belajar di Luar Kelas</h3>
						<p class="text-gray-600">Memperluas wawasan melalui pengalaman belajar langsung di alam dan lingkungan sosial sekitar.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Galeri Kegiatan -->
		<section class="bg-slate-50 py-24">
			<div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
				<h2 class="text-3xl font-bold text-gray-900 sm:text-4xl" data-aos="fade-up">Galeri Kegiatan</h2>
				<p class="mt-4 text-gray-600 mb-12" data-aos="fade-up" data-aos-delay="200">Intip keseruan belajar dan bermain di sekolah kami (Geser untuk melihat)</p>
				
				<!-- Swiper Container -->
				<div class="relative px-4 group" data-aos="zoom-in" data-aos-delay="400">
					<div class="swiper kegiatan-swiper !pb-16">
						<div class="swiper-wrapper">
							{kegiatanList.map((item) => (
								<div class="swiper-slide">
									<div class="group/card relative overflow-hidden rounded-3xl aspect-[4/3] bg-gray-200 transition-all hover:shadow-xl">
										<Image src={item.src} alt={item.label} class="w-full h-full object-cover transition-transform duration-700 group-hover/card:scale-110" />
										<div class="absolute inset-0 bg-gradient-to-t from-emerald-900/90 via-emerald-900/20 to-transparent opacity-0 group-hover/card:opacity-100 transition-all duration-300 flex items-end p-8">
											<p class="text-white font-semibold text-lg italic translate-y-4 group-hover/card:translate-y-0 transition-transform duration-300 text-left">{item.label}</p>
										</div>
									</div>
								</div>
							))}
						</div>
						<div class="swiper-pagination"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimoni -->
		<section class="py-24 bg-white">
			<div class="max-w-6xl mx-auto px-6 lg:px-8">
				<div class="text-center mb-16" data-aos="fade-up">
					<h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Suara Wali Murid</h2>
					<p class="mt-4 text-gray-600">Cerita tulus dari para orang tua yang telah mempercayakan pendidikan putra-putrinya kepada kami.</p>
				</div>
				
				<div class="swiper testimoni-swiper !pb-12" data-aos="fade-up" data-aos-delay="200">
					<div class="swiper-wrapper">
						{testimoniList.map((item) => (
							<div class="swiper-slide flex">
								<div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 flex flex-col w-full">
									<div class="text-emerald-500 mb-4">
										<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V12C14.017 12.5523 13.5693 13 13.017 13H11.017C10.4647 13 10.017 12.5523 10.017 12V9C10.017 7.34315 11.3601 6 13.017 6H19.017C20.6739 6 22.017 7.34315 22.017 9V15C22.017 18.3137 9.33072 21 16.017 21H14.017ZM4.017 21L4.017 18C4.017 16.8954 4.91243 16 6.017 16H9.017C9.56928 16 10.017 15.5523 10.017 15V9C10.017 8.44772 9.56928 8 9.017 8H5.017C4.46472 8 4.017 8.44772 4.017 9V12C4.017 12.5523 3.56928 13 3.017 13H1.017C0.46472 13 0.017 12.5523 0.017 12V9C0.017 7.34315 1.36015 6 3.017 6H9.017C10.6739 6 12.017 7.34315 12.017 9V15C12.017 18.3137 9.33072 21 6.017 21H4.017Z"/></svg>
									</div>
									<p class="text-gray-600 italic leading-relaxed flex-grow">"{item.quote}"</p>
									<div class="mt-8 flex items-center gap-4">
										<div class="h-12 w-12 rounded-full bg-emerald-100 flex items-center justify-center font-bold text-emerald-600">{item.initials}</div>
										<div>
											<h5 class="font-bold text-gray-900 tracking-tight">{item.name}</h5>
											<p class="text-sm text-gray-500 italic">{item.location}</p>
										</div>
									</div>
								</div>
							</div>
						))}
					</div>
					<div class="swiper-pagination"></div>
				</div>
			</div>
		</section>

		<!-- Call to Action Section -->
		<section class="bg-green-700 py-16 text-center text-white overflow-hidden">
			<div data-aos="zoom-in" data-aos-duration="800">
				<h2 class="text-3xl font-bold mb-4">Ingin bergabung bersama kami?</h2>
				<p class="text-green-100 mb-8 max-w-2xl mx-auto px-4">Mari wujudkan masa depan buah hati Anda yang cerdas dan berakhlakul karimah bersama MI Nurul Ulum Sidomukti.</p>
				<a href="/kontak" class="bg-white text-green-700 px-8 py-3 rounded-full font-bold hover:bg-slate-50 transition-colors inline-block">Hubungi Kami</a>
			</div>
		</section>
	</main>

	<Footer />

	<script>
        // 1. Import Swiper dan modul yang dibutuhkan
        import Swiper from 'swiper';
        import { Navigation, Pagination, Autoplay } from 'swiper/modules';

        // 2. Import CSS Swiper langsung di sini

        // 3. Inisialisasi Swiper saat halaman dimuat
        const initSwipers = () => {
            new Swiper('.kegiatan-swiper', {
                modules: [Navigation, Pagination, Autoplay], // Daftarkan modul di sini
                slidesPerView: 1.2,
                spaceBetween: 20,
                centeredSlides: true,
                loop: true,
                autoplay: {
                    delay: 3000,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                breakpoints: {
                    640: { slidesPerView: 2, centeredSlides: false, spaceBetween: 24 },
                    1024: { slidesPerView: 3, centeredSlides: false, spaceBetween: 30 }
                }
            });

            new Swiper('.testimoni-swiper', {
                modules: [Pagination, Autoplay], // Daftarkan modul di sini
                slidesPerView: 1,
                spaceBetween: 20,
                loop: true,
                autoplay: {
                    delay: 5000,
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                breakpoints: {
                    640: { slidesPerView: 2, spaceBetween: 24 },
                    1024: { slidesPerView: 3, spaceBetween: 30 }
                }
            });
        };

        // Jalankan inisialisasi
        initSwipers();

        // Penting: Jika kamu pakai View Transitions, tambahkan listener ini
        document.addEventListener('astro:page-load', initSwipers);
    </script>
</Layout>
